# Environment Configuration Example
# Copy to .env and fill in your values

# Your Telegram user ID (get from @userinfobot on Telegram)
ALLOWED_USER_ID=123456789

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Groq API Key (from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Your location coordinates (Open-Meteo uses these for weather)
LATITUDE=51.5074
LONGITUDE=-0.1278

# Optional: Enable laundry reset notifications
LAUNDRY_NOTIFICATION=false

# Optional: Disable automatic morning outfit suggestions
AUTO_OUTFIT_DISABLED=false

# =============================================================================
# DISCORD BOT CONFIGURATION (discord_bot.py)
# =============================================================================

# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Channel ID for daily messages
CHANNEL_ID=your_channel_id_here

# Secret key for authenticating /daily endpoint (generate a random string)
SECRET_KEY=your_secret_key_here

# Flask server port (optional)
PORT=5000
