# AutoStuff Configuration
# Copy to .env and fill in your values

# =============================================================================
# GENERAL SETTINGS
# =============================================================================

# Your Telegram user ID (get from @userinfobot on Telegram)
ALLOWED_USER_ID=123456789

# Your location coordinates (Open-Meteo uses these for weather)
LATITUDE=51.5074
LONGITUDE=-0.1278

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# TELEGRAM BOT
# =============================================================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# =============================================================================
# AI SERVICES
# =============================================================================

# Groq API Key (from https://console.groq.com)
# Required for: AutoClothes AI outfit suggestions
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# FEATURE TOGGLES
# =============================================================================

# AutoClothes - AI-powered daily outfit suggestions
# Dependencies: TELEGRAM_BOT_TOKEN, GROQ_API_KEY
AUTOCLOTHES_ENABLED=true

# AutoClothes: Disable automatic morning outfit suggestions (manual /outfit only)
AUTO_OUTFIT_DISABLED=false

# AutoClothes: Enable laundry reset notifications on Sunday
LAUNDRY_NOTIFICATION=false

# News Tracking - Daily news digest (coming soon)
NEWS_TRACKING_ENABLED=false

# Price Tracking - Monitor product prices (coming soon)
PRICE_TRACKING_ENABLED=false

# =============================================================================
# DISCORD BOT (discord_bot.py) - Standalone experiment
# =============================================================================
# Note: This is a separate bot that runs independently.
# It's a friendly experiment to remind friends what day it is.

# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Channel ID for daily messages
CHANNEL_ID=your_channel_id_here

# Secret key for authenticating /daily endpoint
SECRET_KEY=your_secret_key_here

# Flask server port (optional)
PORT=5000
